# AI Provider (choose 'gemini' or 'groq')
AI_PROVIDER=gemini

# Your LLM API Key (Get from AI Studio for Gemini or Groq Cloud for Groq)
# WARNING: Keep this secret! Never commit this to Git.
AI_API_KEY=YOUR_API_KEY_HERE

# Resume Settings
# Put your file in the 'resume/' folder and update the path here
RESUME_PATH=resume/your_resume_name.docx
DEFAULT_JOB_SEARCH=Software Engineer

# Personal Details (Used for auto-filling forms)
USER_NAME=Full Name
USER_EMAIL=email@example.com
USER_PHONE=+1234567890
USER_LOCATION=City, Country
USER_LINKEDIN=https://linkedin.com/in/yourprofile
USER_GITHUB=https://github.com/yourusername
USER_PORTFOLIO=https://yourportfolio.com
USER_WEBSITE=
USER_YEARS_EXPERIENCE=2
